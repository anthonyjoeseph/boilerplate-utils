{
  "name": "@boilerplate-utils/example-ssr",
  "version": "0.0.0",
  "private": true,
  "description": "Server-side-rendered example: Express serving React, with Vite as the dev middleware",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "vite-node --watch server-index.ts",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr entry-server.tsx",
    "build": "pnpm run build:client && pnpm run build:server",
    "start": "NODE_ENV=production vite-node server-index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@boilerplate-utils/react": "workspace:*",
    "express": "^4.21.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "catalog:",
    "vite": "^5.4.21",
    "vite-node": "^2.1.8"
  }
}

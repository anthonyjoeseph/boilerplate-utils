{
  "name": "@boilerplate-utils/react",
  "version": "0.0.1",
  "description": "Hook-free, Observable-based React component utilities (cycler & nester)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },

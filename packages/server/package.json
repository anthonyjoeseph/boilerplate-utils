{
  "name": "@boilerplate-utils/server",
  "version": "0.0.1",
  "description": "SSR / static-render example server for a boilerplate-utils app",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@boilerplate-utils/react": "workspace:*",
    "express": "^4.21.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "rxjs": "^7.8.1",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "rxjs": "catalog:",
    "typescript": "catalog:",
    "vite": "^5.4.21",
    "vitest": "catalog:"
  }
}

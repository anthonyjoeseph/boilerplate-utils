{
  "name": "smart-inline-function",
  "displayName": "Smart Inline Function",
  "description": "Inline TypeScript function calls with smart beta-reduction and conditional simplification, across files and (where possible) npm modules with source maps.",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "anthonyjoeseph",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartInlineFunction.inline",
        "title": "Smart Inline",
        "category": "Refactor"
      }
    ],
    "keybindings": [
      {
        "command": "smartInlineFunction.inline",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "editorTextFocus && (editorLangId == 'typescript' || editorLangId == 'typescriptreact')"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "catalog:",
    "@types/vscode": "^1.109.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "typescript-eslint": "^8.56.1",
    "vitest": "catalog:"
  }
}
